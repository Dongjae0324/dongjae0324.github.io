@inproceedings{yoon2026dpo_attack,
  title={Few-Shot Truly Benign DPO Attack for Jailbreaking LLMs},
  author = {Yoon, Sangyeon and Jeung, Wonje and Cho, Yoonjun and Jeon, Dongjae and No, Albert},
  coauthor={Sangyeon Yoon, Wonje Jeung},
  booktitle  = {Under Review},
  year      = {2026},
  pub_id = {P3},
  html = {https://arxiv.org/},
  img = {assets/img/publications/dpo_attack.jpg},
  tldr = {We propose a truly benign DPO attack that jailbreaks frontier LLMs using only 10 harmless preference pairs that look indistinguishable from ordinary over-refusal reduction data, pairing benign prompts with a helpful answer (preferred) and a refusal (dispreferred). Because DPO directly suppresses refusal behavior, the effect transfers to unseen harmful prompts, reaching up to 81.73% ASR on GPT-4.1-nano for $0.1 while evading the OpenAI Moderation API and frontier-scale LLM auditors.},
}
